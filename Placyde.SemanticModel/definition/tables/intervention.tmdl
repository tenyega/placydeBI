	column 'Durée intervention' = ```
			
			-- 1. On force la conversion en nombre. Si c'est "NULL", IFERROR renvoie du vide (BLANK)
			VAR HeureSurPlace = IFERROR(VALUE('intervention'[heure_appel_sur_place]), BLANK())
			VAR HeureContact = IFERROR(VALUE('intervention'[heure_contact_pc]), BLANK())
			VAR HeureFin = IFERROR(VALUE('intervention'[heure_fin]), BLANK())
			
			-- 2. On choisit l'heure de début selon votre priorité
			VAR Debut = IF(ISBLANK(HeureSurPlace), HeureContact, HeureSurPlace)
			
			-- 3. On calcule l'écart uniquement si on a un début et une fin
			RETURN
			IF(
			    ISBLANK(Debut) || ISBLANK(HeureFin), 
			    0,
			    VAR Ecart = ROUND((HeureFin - Debut) * 1440, 0)
			    RETURN IF(Ecart < 0, 0, Ecart)
			)
			```
		lineageTag: f9a8f403-b092-41e5-a8be-9c863ebd4186
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'réactivité agent (min)' = ```
			
			-- 1. On convertit les heures en nombres, gère le texte "NULL"
			VAR Debut = IFERROR(VALUE('intervention'[heure_contact_pc]), BLANK())
			VAR Arrivee = IFERROR(VALUE('intervention'[heure_appel_sur_place]), BLANK())
			
			-- 2. On vérifie que les DEUX valeurs existent
			RETURN
			IF(
			    ISBLANK(Debut) || ISBLANK(Arrivee), 
			    BLANK(), -- Renvoie un vrai vide si une donnée manque
			    VAR Ecart = ROUND((Arrivee - Debut) * 1440, 0)
			    RETURN IF(Ecart < 0, 0, Ecart)
			)
			```
		lineageTag: 8a25bc87-a38e-470f-8b81-1d48c52c2793
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

