	measure 'High Reactivity %' =
			
			DIVIDE(
			    COUNTROWS(
			        FILTER(
			            'intervention',
			            'intervention'[réactivité agent (min)] > 30
			        )
			    ),
			    COUNTROWS('intervention'),
			    0
			)
